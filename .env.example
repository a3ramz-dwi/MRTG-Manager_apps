APP_NAME="MRTG Manager Apps"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_DIR=/var/www/apps
APP_SECRET=change-this-secret
APP_TIMEZONE=Asia/Jakarta

HOSTNAME=apps-mrtg
SERVER_IP=10.0.0.1

APACHE_SERVER_NAME=localhost
APACHE_SERVER_ALIAS="apps-mrtg.local mrtg.local"

DB_HOST=localhost
DB_PORT=3306
DB_NAME=mrtg_manager
DB_USER=mrtg_user
DB_PASS=secret
DB_CHARSET=utf8mb4

MRTG_DIR=/var/www/mrtg
MRTG_CFG=/etc/mrtg
MRTG_BIN=/usr/bin/mrtg

LOG_DIR=/var/log/apps

SESSION_DRIVER=file
SESSION_LIFETIME=7200
SESSION_PATH=/var/www/apps/storage/sessions
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

SNMP_TIMEOUT=1000000
SNMP_RETRIES=1
SNMP_DEFAULT_PORT=161

MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_FROM="noreply@example.com"
MAIL_FROM_NAME="MRTG Manager Apps"
